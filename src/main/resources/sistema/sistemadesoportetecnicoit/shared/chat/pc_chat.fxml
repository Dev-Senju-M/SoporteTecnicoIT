<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="420.0" prefWidth="520.0" spacing="0.0"
      styleClass="chat-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.shared.chat.ChatController">
    <stylesheets>
        <String fx:value="/sistema/sistemadesoportetecnicoit/shared/chat/chat.css"/>
    </stylesheets>
    <VBox spacing="2.0" styleClass="chat-header">
        <Label styleClass="chat-title" text="CHAT — SOPORTE TECNICO IT"/>
        <Label styleClass="chat-subtitle" text="Mensajes visibles por todas las estaciones conectadas"/>
    </VBox>
    <TextArea fx:id="areaChat"
              VBox.vgrow="ALWAYS"
              editable="false"
              wrapText="true"
              styleClass="chat-area"/>
    <HBox spacing="8.0" styleClass="input-bar" alignment="CENTER_LEFT">
        <TextField fx:id="txtMensaje"
                   HBox.hgrow="ALWAYS"
                   promptText="Escribe un mensaje..."
                   styleClass="input-field"/>
        <Button fx:id="btnEnviar"
                onAction="#enviar"
                styleClass="btn-send"
                text="Enviar"/>
    </HBox>
</VBox>
