<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="screenRoot" prefHeight="440.0" prefWidth="440.0" spacing="0.0"
      styleClass="screen-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc2.MenuController">
    <stylesheets>
        <String fx:value="/sistema/sistemadesoportetecnicoit/pc2/pc2.css"/>
    </stylesheets>

    <VBox fx:id="panelHeader" maxWidth="Infinity" spacing="4.0" styleClass="panel-header">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <FontIcon iconLiteral="fas-headset" iconSize="18" styleClass="header-icon"/>
            <VBox spacing="2.0">
                <Label styleClass="header-title" text="SOPORTE TECNICO IT"/>
                <Label styleClass="header-subtitle" text="Sistema de Gestion de Tickets — PC2"/>
            </VBox>
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" maxWidth="Infinity" spacing="0.0" styleClass="screen-body">
        <Label styleClass="section-label" text="ACCIONES"/>
        <Region prefHeight="12.0"/>

        <VBox spacing="5.0">
            <Button onAction="#abrirRegistro"
                    maxWidth="Infinity" prefHeight="44.0"
                    styleClass="btn-primary"
                    text="Registrar Nuevo Ticket">
                <graphic>
                    <FontIcon iconLiteral="fas-plus-circle" iconSize="14" iconColor="#ffffff"/>
                </graphic>
            </Button>
            <Label styleClass="desc-label"
                   text="Abre un nuevo ticket y lo envia al area de soporte"/>
        </VBox>

        <Region prefHeight="10.0"/>

        <VBox spacing="5.0">
            <Button onAction="#abrirHistorial"
                    maxWidth="Infinity" prefHeight="44.0"
                    styleClass="btn-secondary"
                    text="Consultar Historial por DPI">
                <graphic>
                    <FontIcon iconLiteral="fas-history" iconSize="14" styleClass="icon-secondary"/>
                </graphic>
            </Button>
            <Label styleClass="desc-label"
                   text="Consulta los tickets registrados asociados a tu DPI"/>
        </VBox>

        <Region prefHeight="20.0"/>

        <Button onAction="#abrirChat"
                prefHeight="36.0" maxWidth="Infinity"
                styleClass="btn-chat"
                text="Abrir Chat">
            <graphic>
                <FontIcon iconLiteral="fas-comments" iconSize="13" styleClass="icon-chat"/>
            </graphic>
        </Button>

        <Region prefHeight="10.0"/>

        <Button onAction="#salir"
                prefHeight="32.0" prefWidth="110.0"
                styleClass="btn-ghost"
                text="Salir">
            <graphic>
                <FontIcon iconLiteral="fas-sign-out-alt" iconSize="12" styleClass="icon-ghost"/>
            </graphic>
        </Button>
    </VBox>

    <HBox maxWidth="Infinity" alignment="CENTER_LEFT" spacing="8.0" styleClass="panel-footer">
        <Label fx:id="lblServidor" text="Servidor: —"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#toggleTema" styleClass="btn-ghost-sm" prefHeight="28.0">
            <graphic>
                <FontIcon fx:id="iconTema" iconLiteral="fas-sun" iconSize="13" styleClass="icon-ghost"/>
            </graphic>
        </Button>
    </HBox>
</VBox>
