<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="380.0" prefWidth="420.0" spacing="18.0"
      style="-fx-background-color: #2b2b2b; -fx-background-radius: 6;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc2.MenuController">
   <padding>
      <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
   </padding>
   <children>
      <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #00c8ff;"
             text="Soporte Tecnico IT"/>
      <Label style="-fx-font-size: 13px; -fx-text-fill: #cccccc;"
             text="PC2 - Registro de Tickets"/>
      <Label style="-fx-font-size: 11px; -fx-text-fill: #888888;"
             text="Seleccione una opcion para continuar"/>

      <Button onAction="#abrirRegistro"
              prefHeight="48.0" prefWidth="260.0"
              style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
              text="Registrar Nuevo Ticket"/>

      <Button onAction="#abrirHistorial"
              prefHeight="48.0" prefWidth="260.0"
              style="-fx-background-color: #555555; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
              text="Consultar Historial por DPI"/>

      <Button onAction="#salir"
              prefHeight="36.0" prefWidth="160.0"
              style="-fx-background-color: transparent; -fx-text-fill: #aaaaaa; -fx-font-size: 12px; -fx-border-color: #555555; -fx-border-radius: 8; -fx-cursor: hand;"
              text="Salir"/>

      <Label fx:id="lblServidor"
             style="-fx-font-size: 10px; -fx-text-fill: #666666; -fx-font-style: italic;"
             text="Servidor: -"/>
   </children>
</VBox>