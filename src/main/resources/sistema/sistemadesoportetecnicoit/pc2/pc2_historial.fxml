<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="520.0" prefWidth="753.0" spacing="0.0"
      styleClass="screen-root"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc2.HistorialController">
    <stylesheets>
        <String fx:value="/sistema/sistemadesoportetecnicoit/pc2/pc2.css"/>
    </stylesheets>

    <VBox spacing="4.0" styleClass="panel-header">
        <Label styleClass="header-title" text="Historial de Tickets"/>
        <Label styleClass="header-subtitle" text="Consulta al servidor central (PC1) mediante arbol B+"/>
    </VBox>

    <VBox spacing="0.0" styleClass="search-section">
        <Label styleClass="section-label" text="BUSQUEDA POR DPI"/>
        <Region prefHeight="8.0"/>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <TextField fx:id="txtDpiBuscar" prefWidth="220.0" promptText="13 digitos"/>
            <Button onAction="#buscar"
                    prefHeight="36.0" prefWidth="100.0"
                    styleClass="btn-primary-sm"
                    text="Buscar"/>
            <Button onAction="#limpiar"
                    prefHeight="36.0" prefWidth="90.0"
                    styleClass="btn-secondary-sm"
                    text="Limpiar"/>
        </HBox>
    </VBox>

    <TableView fx:id="tablaTickets" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTicketId"    prefWidth="100.0" text="Ticket ID"/>
            <TableColumn fx:id="colDpi"         prefWidth="130.0" text="DPI"/>
            <TableColumn fx:id="colNombre"      prefWidth="165.0" text="Nombre"/>
            <TableColumn fx:id="colMotivo"      prefWidth="150.0" text="Motivo"/>
            <TableColumn fx:id="colTipo"        prefWidth="110.0" text="Tipo"/>
            <TableColumn fx:id="colTiempoTotal" prefWidth="100.0" text="Tiempo (min)"/>
        </columns>
        <placeholder>
            <Label styleClass="placeholder-label"
                   text="Sin resultados. Ingrese un DPI y presione Buscar."/>
        </placeholder>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="panel-footer">
        <Button onAction="#regresarMenu"
                prefHeight="34.0" prefWidth="110.0"
                styleClass="btn-secondary-sm"
                text="Regresar"/>
        <Label fx:id="lblEstado" text=" "/>
    </HBox>
</VBox>