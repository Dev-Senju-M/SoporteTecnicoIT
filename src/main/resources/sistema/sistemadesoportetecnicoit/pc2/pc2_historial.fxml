<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="screenRoot" prefHeight="520.0" prefWidth="753.0" spacing="0.0"
      styleClass="screen-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc2.HistorialController">
    <stylesheets>
        <String fx:value="/sistema/sistemadesoportetecnicoit/pc2/pc2.css"/>
    </stylesheets>

    <VBox fx:id="panelHeader" maxWidth="Infinity" spacing="4.0" styleClass="panel-header">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <FontIcon iconLiteral="fas-history" iconSize="16" styleClass="header-icon"/>
            <VBox spacing="2.0">
                <Label styleClass="header-title" text="HISTORIAL DE TICKETS"/>
                <Label styleClass="header-subtitle" text="Consulta al servidor central (PC1)"/>
            </VBox>
        </HBox>
    </VBox>

    <VBox maxWidth="Infinity" spacing="0.0" styleClass="search-section">
        <Label styleClass="section-label" text="BUSQUEDA POR DPI"/>
        <Region prefHeight="8.0"/>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <TextField fx:id="txtDpiBuscar" HBox.hgrow="ALWAYS" promptText="13 digitos"/>
            <Button onAction="#buscar"
                    prefHeight="36.0" prefWidth="100.0"
                    styleClass="btn-primary-sm"
                    text="Buscar">
                <graphic>
                    <FontIcon iconLiteral="fas-search" iconSize="12" iconColor="#ffffff"/>
                </graphic>
            </Button>
            <Button onAction="#limpiar"
                    prefHeight="36.0" prefWidth="90.0"
                    styleClass="btn-secondary-sm"
                    text="Limpiar">
                <graphic>
                    <FontIcon iconLiteral="fas-times" iconSize="11" styleClass="icon-secondary"/>
                </graphic>
            </Button>
        </HBox>
    </VBox>

    <TableView fx:id="tablaTickets" maxWidth="Infinity" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTicketId"    prefWidth="100.0" text="Ticket ID"/>
            <TableColumn fx:id="colDpi"         prefWidth="130.0" text="DPI"/>
            <TableColumn fx:id="colNombre"      prefWidth="165.0" text="Nombre"/>
            <TableColumn fx:id="colMotivo"      prefWidth="150.0" text="Motivo"/>
            <TableColumn fx:id="colTipo"        prefWidth="110.0" text="Tipo"/>
            <TableColumn fx:id="colTiempoTotal" prefWidth="100.0" text="Tiempo (min)"/>
        </columns>
        <placeholder>
            <Label styleClass="placeholder-label"
                   text="Sin resultados. Ingrese un DPI y presione Buscar."/>
        </placeholder>
    </TableView>

    <HBox maxWidth="Infinity" alignment="CENTER_LEFT" spacing="12.0" styleClass="panel-footer">
        <Button onAction="#regresarMenu"
                prefHeight="34.0" prefWidth="110.0"
                styleClass="btn-secondary-sm"
                text="Regresar">
            <graphic>
                <FontIcon iconLiteral="fas-chevron-left" iconSize="11" styleClass="icon-secondary"/>
            </graphic>
        </Button>
        <Label fx:id="lblEstado" text=" "/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#toggleTema" styleClass="btn-ghost-sm" prefHeight="28.0">
            <graphic>
                <FontIcon fx:id="iconTema" iconLiteral="fas-sun" iconSize="13" styleClass="icon-ghost"/>
            </graphic>
        </Button>
    </HBox>
</VBox>
