<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="460.0" spacing="14.0"
      style="-fx-background-color: #2b2b2b; -fx-padding: 25; -fx-background-radius: 6;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc2.RegistroController">
    <children>
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #00c8ff;"
               text="Registrar Nuevo Ticket"/>

        <Label fx:id="lblTicketId"
               style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px; -fx-font-style: italic;"
               text="Ticket: TK-0000"/>

        <GridPane hgap="10.0" vgap="12.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="140.0"/>
                <ColumnConstraints hgrow="ALWAYS"    minWidth="200.0" prefWidth="240.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="32.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="32.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="32.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="32.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="32.0" vgrow="SOMETIMES"/>
            </rowConstraints>
            <children>
                <Label style="-fx-text-fill: #bbbbbb; -fx-font-size: 12px;" text="DPI:"/>
                <TextField fx:id="txtDpi" promptText="13 digitos"
                           style="-fx-background-color: #3c3c3c; -fx-text-fill: white;"
                           GridPane.columnIndex="1"/>

                <Label style="-fx-text-fill: #bbbbbb; -fx-font-size: 12px;" text="Nombre y Apellido:"
                       GridPane.rowIndex="1"/>
                <TextField fx:id="txtNombre" promptText="Ej. Juan Perez"
                           style="-fx-background-color: #3c3c3c; -fx-text-fill: white;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label style="-fx-text-fill: #bbbbbb; -fx-font-size: 12px;" text="Tipo de problema:"
                       GridPane.rowIndex="2"/>
                <ComboBox fx:id="cmbTipo" onAction="#actualizarDestino" prefWidth="240.0"
                          style="-fx-background-color: #3c3c3c; -fx-text-fill: white;"
                          GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label fx:id="lblMotivoLabel"
                       style="-fx-text-fill: #bbbbbb; -fx-font-size: 12px;" text="Motivo:"
                       visible="false" GridPane.rowIndex="3"/>
                <TextField fx:id="txtMotivo" promptText="Describa el problema"
                           style="-fx-background-color: #3c3c3c; -fx-text-fill: white;"
                           visible="false"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label style="-fx-text-fill: #bbbbbb; -fx-font-size: 12px;" text="Sera atendido en:"
                       GridPane.rowIndex="4"/>
                <Label fx:id="lblDestino"
                       style="-fx-text-fill: #00c8ff; -fx-font-size: 13px; -fx-font-weight: bold;"
                       text="PC3 - Soporte N1"
                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </children>
        </GridPane>

        <HBox alignment="CENTER" spacing="12.0">
            <children>
                <Button onAction="#enviarTicket"
                        prefHeight="40.0" prefWidth="180.0"
                        style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                        text="Enviar Ticket"/>
                <Button onAction="#regresarMenu"
                        prefHeight="40.0" prefWidth="120.0"
                        style="-fx-background-color: #555555; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"
                        text="Regresar"/>
            </children>
        </HBox>

        <Label fx:id="lblEstado"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"
               text=" "/>
    </children>
</VBox>