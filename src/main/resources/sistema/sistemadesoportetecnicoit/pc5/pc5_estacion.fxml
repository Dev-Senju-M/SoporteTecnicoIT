<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="380.0" prefWidth="440.0" spacing="16.0"
      styleClass="screen-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc5.EstacionController">
    <stylesheets>
        <String fx:value="/sistema/sistemadesoportetecnicoit/pc5/pc5.css"/>
    </stylesheets>
    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>
    <children>
        <Label styleClass="screen-title-md" text="Estacion de Soporte Especial"/>
        <Label fx:id="lblTecnico" styleClass="info-label" text="Tecnico: -"/>
        <Label styleClass="screen-subtitle" text="Atiende: Tickets Especiales"/>

        <Label fx:id="lblEstado" styleClass="estado-label" text="En espera de tickets especiales..."/>

        <ProgressIndicator fx:id="spinner" visible="false" prefHeight="40.0" prefWidth="40.0"/>

        <Button fx:id="btnAtender" onAction="#atenderSiguiente"
                prefHeight="44.0" prefWidth="240.0"
                styleClass="btn-primary"
                text="Atender Ticket Especial"/>

        <Label fx:id="lblInfo" styleClass="muted-label" text=" "/>

        <Button onAction="#abrirChat"
                prefHeight="36.0" prefWidth="240.0"
                styleClass="btn-chat"
                text="Abrir Chat"/>
    </children>
</VBox>
