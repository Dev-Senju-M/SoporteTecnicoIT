<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="640.0" prefWidth="560.0" spacing="12.0"
      styleClass="screen-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc5.AtencionController">
    <stylesheets>
        <String fx:value="/sistema/sistemadesoportetecnicoit/pc5/pc5.css"/>
    </stylesheets>
    <padding>
        <Insets top="20.0" right="25.0" bottom="20.0" left="25.0"/>
    </padding>
    <children>
        <Label styleClass="screen-title-md" text="Atencion de Ticket Especial"/>

        <VBox spacing="3.0">
            <children>
                <Label fx:id="lblTicketInfo" styleClass="info-label" text="Ticket: -"/>
                <Label fx:id="lblUsuario"    styleClass="info-label" text="Usuario: -"/>
                <Label fx:id="lblTipo"       styleClass="info-label" text="Tipo: -"/>
                <Label fx:id="lblMotivoOriginal" styleClass="motivo-label" text=""/>
            </children>
        </VBox>

        <Label styleClass="section-label" text="Diagnostico:"/>

        <ScrollPane fitToWidth="true" prefHeight="280.0" styleClass="scroll-dark">
            <content>
                <VBox fx:id="contPreguntas" spacing="10.0" styleClass="preguntas-box"/>
            </content>
        </ScrollPane>

        <ProgressBar fx:id="barraSimulacion" visible="false" prefWidth="510.0" progress="0.0"/>
        <Label fx:id="lblSimulacion" styleClass="muted-label" text=" "/>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="btnIniciar" onAction="#iniciarSimulacion"
                        prefHeight="38.0" prefWidth="170.0"
                        styleClass="btn-iniciar"
                        text="Iniciar Atencion"/>
                <Button fx:id="btnFinalizar" onAction="#finalizar" disable="true"
                        prefHeight="38.0" prefWidth="170.0"
                        styleClass="btn-success"
                        text="Finalizar y Enviar"/>
            </children>
        </HBox>
    </children>
</VBox>
