<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="380.0" spacing="14.0"
      style="-fx-background-color: #2b2b2b; -fx-background-radius: 6;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc5.LoginController">
    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>
    <children>
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ce93d8;"
               text="PC5 - Soporte Especial"/>
        <Label style="-fx-font-size: 11px; -fx-text-fill: #888888;"
               text="Identifiquese para iniciar la sesion"/>

        <TextField fx:id="txtNombre" promptText="Nombre del tecnico"
                   style="-fx-background-color: #3c3c3c; -fx-text-fill: white;"/>

        <Button onAction="#iniciar"
                prefHeight="40.0" prefWidth="200.0"
                style="-fx-background-color: #6a1b9a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                text="Iniciar Sesion"/>

        <Label fx:id="lblError"
               style="-fx-text-fill: #e57373; -fx-font-size: 11px;"
               text=" "/>
    </children>
</VBox>
