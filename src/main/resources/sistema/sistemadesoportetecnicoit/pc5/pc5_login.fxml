<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="380.0" spacing="14.0"
      styleClass="screen-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc5.LoginController">
    <stylesheets>
        <String fx:value="/sistema/sistemadesoportetecnicoit/pc5/pc5.css"/>
    </stylesheets>
    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>
    <children>
        <Label styleClass="screen-title" text="PC5 - Soporte Especial"/>
        <Label styleClass="screen-subtitle" text="Identifiquese para iniciar la sesion"/>

        <TextField fx:id="txtNombre" promptText="Nombre del tecnico"
                   styleClass="text-field-dark"/>

        <Button onAction="#iniciar"
                prefHeight="40.0" prefWidth="200.0"
                styleClass="btn-primary"
                text="Iniciar Sesion"/>

        <Label fx:id="lblError" styleClass="error-label" text=" "/>
    </children>
</VBox>
