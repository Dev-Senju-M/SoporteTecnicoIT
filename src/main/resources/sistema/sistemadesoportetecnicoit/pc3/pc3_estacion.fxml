<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="380.0" prefWidth="440.0" spacing="16.0"
      style="-fx-background-color: #2b2b2b; -fx-background-radius: 6;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc3.EstacionController">
    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>
    <children>
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #00c8ff;"
               text="Estacion de Soporte N1"/>
        <Label fx:id="lblTecnico"
               style="-fx-font-size: 12px; -fx-text-fill: #cccccc;"
               text="Tecnico: -"/>
        <Label style="-fx-font-size: 11px; -fx-text-fill: #888888;"
               text="Atiende: Hardware, Software, Conectividad"/>

        <Label fx:id="lblEstado"
               style="-fx-font-size: 13px; -fx-text-fill: #cccccc;"
               text="En espera de tickets..."/>

        <ProgressIndicator fx:id="spinner" visible="false" prefHeight="40.0" prefWidth="40.0"/>

        <Button fx:id="btnAtender" onAction="#atenderSiguiente"
                prefHeight="44.0" prefWidth="240.0"
                style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                text="Atender Siguiente Ticket"/>

        <Label fx:id="lblInfo"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"
               text=" "/>
    </children>
</VBox>