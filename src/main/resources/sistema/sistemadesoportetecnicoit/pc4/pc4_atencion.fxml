<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="640.0" prefWidth="560.0" spacing="12.0"
      style="-fx-background-color: #2b2b2b;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sistema.sistemadesoportetecnicoit.pc4.AtencionController">
    <padding>
        <Insets top="20.0" right="25.0" bottom="20.0" left="25.0"/>
    </padding>
    <children>
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ff8f00;"
               text="Atencion de Ticket Prioritario"/>

        <VBox spacing="3.0">
            <children>
                <Label fx:id="lblTicketInfo"
                       style="-fx-font-size: 12px; -fx-text-fill: #cccccc;" text="Ticket: -"/>
                <Label fx:id="lblUsuario"
                       style="-fx-font-size: 12px; -fx-text-fill: #cccccc;" text="Usuario: -"/>
                <Label fx:id="lblTipo"
                       style="-fx-font-size: 12px; -fx-text-fill: #cccccc;" text="Tipo: -"/>
                <Label fx:id="lblMotivoOriginal"
                       style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa; -fx-font-style: italic;" text=""/>
            </children>
        </VBox>

        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #cccccc;"
               text="Diagnostico:"/>

        <ScrollPane fitToWidth="true" prefHeight="280.0"
                    style="-fx-background: #2b2b2b; -fx-background-color: #2b2b2b;">
            <content>
                <VBox fx:id="contPreguntas" spacing="10.0"
                      style="-fx-background-color: #2b2b2b;"/>
            </content>
        </ScrollPane>

        <ProgressBar fx:id="barraSimulacion" visible="false" prefWidth="510.0" progress="0.0"/>
        <Label fx:id="lblSimulacion"
               style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;" text=" "/>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="btnIniciar" onAction="#iniciarSimulacion"
                        prefHeight="38.0" prefWidth="170.0"
                        style="-fx-background-color: #e65100; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        text="Iniciar Atencion"/>
                <Button fx:id="btnFinalizar" onAction="#finalizar" disable="true"
                        prefHeight="38.0" prefWidth="170.0"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        text="Finalizar y Enviar"/>
            </children>
        </HBox>
    </children>
</VBox>
